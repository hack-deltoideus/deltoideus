PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Configure Google OAuth in Supabase Auth and set your Site URL / redirect URLs there.
GEMINI_KEY=YOUR_GEMINI_API_KEY
# Optional backup key used automatically if the primary key is rate-limited.
GEMINI_FALLBACK_KEY=YOUR_SECOND_GEMINI_API_KEY
# Or provide multiple keys as a comma-separated list.
# GEMINI_KEYS=key_one,key_two,key_three
# You can also use GEMINI_API_KEY or GOOGLE_API_KEY instead of GEMINI_KEY.
GEMINI_MODEL=gemini-2.5-flash-lite
